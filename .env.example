# LLM provider: deepseek or google
# DeepSeek is the default provider. Switch to google/gemini later if needed.
LLM_PROVIDER=deepseek

# Gemini settings
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash-lite

# DeepSeek settings
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional project paths. Leave blank to keep the current auto-detection behavior.
# DATA_ROOT can point at your TBM root folder; the other paths override subfolders individually.
DATA_ROOT=
DATA_DIR=
TSP_DIR=
HSP_DIR=
SKETCH_DIR=
DRILL_DIR=
DB_DIR=
RESULT_DIR=
LOG_DIR=
DAILY_RESULT_DIR=
HISTORY_MEMORY_DIR=
APP_DB_PATH=
EVIDENCE_DB_PATH=

# Analysis parameters
TOLERANCE_M=3.0
HIGH_RISK_LOOKAHEAD_M=10.0
NEXT_FORECAST_LOOKAHEAD_M=5.0
